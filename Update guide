<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Te Whare Mā - Guest Guide</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        :root {
            --ocean-deep: #1a3a3a;
            --ocean-mid: #2d5a5a;
            --sand: #f5f1e8;
            --warm-white: #faf8f5;
            --sunset: #c9a66b;
            --text-dark: #2c3e3e;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--warm-white);
            color: var(--text-dark);
            line-height: 1.8;
            overflow-x: hidden;
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            background: linear-gradient(135deg, var(--ocean-deep) 0%, var(--ocean-mid) 50%, #4a7c7c 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29 22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 63c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57-13c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-9-21c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM60 91c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM35 41c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 60c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.03' fill-rule='evenodd'/%3E%3C/svg%3E");
            opacity: 0.3;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            padding: 2rem;
            animation: fadeInUp 1.2s ease-out;
        }

        .hero h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 8vw, 6rem);
            color: var(--sand);
            font-weight: 400;
            letter-spacing: 0.15em;
            margin-bottom: 0.5rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .hero .subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.2rem, 3vw, 1.8rem);
            color: rgba(245, 241, 232, 0.9);
            font-style: italic;
            margin-bottom: 2rem;
            letter-spacing: 0.1em;
        }

        .hero .location {
            font-size: 0.9rem;
            color: rgba(245, 241, 232, 0.7);
            text-transform: uppercase;
            letter-spacing: 0.3em;
            margin-bottom: 3rem;
        }

        .scroll-indicator {
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            color: var(--sand);
            font-size: 0.8rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            animation: bounce 2s infinite;
            cursor: pointer;
        }

        .scroll-indicator::after {
            content: '↓';
            display: block;
            text-align: center;
            margin-top: 0.5rem;
            font-size: 1.5rem;
        }

        /* Navigation Dots */
        .nav-dots {
            position: fixed;
            right: 2rem;
            top: 50%;
            transform: translateY(-50%);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .nav-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(45, 90, 90, 0.3);
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .nav-dot.active {
            background: var(--ocean-mid);
            transform: scale(1.3);
            border-color: var(--sunset);
        }

        /* Sections */
        section {
            min-height: 100vh;
            padding: 4rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }

        .section-content {
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 5vw, 3rem);
            color: var(--ocean-deep);
            margin-bottom: 3rem;
            text-align: center;
            position: relative;
            padding-bottom: 1rem;
        }

        h2::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 2px;
            background: var(--sunset);
        }

        h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            color: var(--ocean-deep);
            margin: 2rem 0 1rem 0;
        }

        /* Welcome Section */
        .welcome {
            background: var(--sand);
        }

        .welcome-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            line-height: 2;
            text-align: center;
            color: var(--ocean-deep);
            margin-bottom: 3rem;
        }

        .kia-ora {
            font-size: 2rem;
            color: var(--ocean-mid);
            display: block;
            margin-bottom: 1rem;
        }

        /* Info Cards */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .info-card {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-left: 4px solid var(--sunset);
        }

        .info-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        }

        .info-card h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.3rem;
            color: var(--ocean-deep);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .icon {
            font-size: 1.5rem;
        }

        /* Guidelines Section */
        .guidelines {
            background: white;
        }

        .guideline-item {
            display: flex;
            align-items: flex-start;
            gap: 1.5rem;
            padding: 1.5rem;
            margin-bottom: 1rem;
            background: var(--warm-white);
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .guideline-item:hover {
            background: var(--sand);
            transform: translateX(10px);
        }

        .guideline-icon {
            font-size: 2rem;
            flex-shrink: 0;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--ocean-deep);
            color: white;
            border-radius: 50%;
        }

        .guideline-content h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            color: var(--ocean-deep);
            margin-bottom: 0.5rem;
        }

        /* Streaming Section */
        .streaming-section {
            background: linear-gradient(to bottom, var(--warm-white), var(--sand));
        }

        .streaming-card {
            background: white;
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            border-left: 4px solid #e50914;
        }

        .streaming-card h3 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .streaming-steps {
            list-style: none;
            padding: 0;
            margin: 1.5rem 0;
        }

        .streaming-steps li {
            padding: 0.8rem 0;
            padding-left: 2rem;
            position: relative;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .streaming-steps li:last-child {
            border-bottom: none;
        }

        .streaming-steps li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: var(--ocean-mid);
            font-weight: bold;
        }

        .streaming-logos {
            display: flex;
            gap: 1rem;
            margin: 1.5rem 0;
            flex-wrap: wrap;
        }

        .streaming-logo {
            background: var(--warm-white);
            padding: 0.5rem 1rem;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .reminder-box {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 1.2rem;
            margin-top: 1.5rem;
            border-radius: 4px;
        }

        .reminder-box strong {
            color: #856404;
        }

        /* Appliance Section */
        .appliance-section {
            background: var(--sand);
        }

        .appliance-card {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .appliance-card h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.3rem;
            color: var(--ocean-deep);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .step-list {
            list-style: none;
            padding: 0;
        }

        .step-list li {
            padding: 0.8rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            display: flex;
            gap: 1rem;
            align-items: flex-start;
        }

        .step-list li:last-child {
            border-bottom: none;
        }

        .step-number {
            background: var(--ocean-mid);
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            font-weight: 600;
            flex-shrink: 0;
        }

        .warning-box {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 1rem;
            margin: 1rem 0;
            border-radius: 4px;
        }

        .warning-box strong {
            color: #856404;
        }

        /* Dining Section */
        .dining-section {
            background: white;
        }

        .restaurant-card {
            background: var(--warm-white);
            padding: 2rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--sunset);
            transition: all 0.3s ease;
        }

        .restaurant-card:hover {
            transform: translateX(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .restaurant-card h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            color: var(--ocean-deep);
            margin-bottom: 0.5rem;
        }

        .restaurant-meta {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            color: var(--ocean-mid);
        }

        .tag {
            background: var(--sand);
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
        }

        /* Activities Section */
        .activities-section {
            background: linear-gradient(to bottom, var(--warm-white), var(--sand));
        }

        .activity-card {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }

        .activity-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--ocean-mid);
        }

        .activity-card h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            color: var(--ocean-deep);
            margin-bottom: 0.5rem;
        }

        .activity-meta {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            color: var(--ocean-mid);
        }

        .difficulty {
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .difficulty.easy {
            background: #d4edda;
            color: #155724;
        }

        .difficulty.medium {
            background: #fff3cd;
            color: #856404;
        }

        .difficulty.hard {
            background: #f8d7da;
            color: #721c24;
        }

        /* Cat Section */
        .cat-section {
            background: linear-gradient(to bottom, var(--warm-white), var(--sand));
            text-align: center;
        }

        .cat-container {
            background: white;
            padding: 3rem;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            margin-top: 2rem;
            position: relative;
            overflow: hidden;
        }

        .cat-container::before {
            content: '🐱';
            position: absolute;
            top: -20px;
            right: -20px;
            font-size: 8rem;
            opacity: 0.05;
            transform: rotate(-15deg);
        }

        .cat-paw {
            display: inline-block;
            animation: wave 2s infinite;
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .cat-warning {
            background: #f8d7da;
            border-left: 4px solid #dc3545;
            padding: 1.2rem;
            margin: 1.5rem 0;
            border-radius: 4px;
            text-align: left;
        }

        .cat-warning strong {
            color: #721c24;
        }

        /* Contact Section */
        .contact {
            background: var(--ocean-deep);
            color: var(--sand);
            text-align: center;
        }

        .contact h2 {
            color: var(--sand);
        }

        .contact h2::after {
            background: var(--sunset);
        }

        .contact-card {
            background: rgba(255,255,255,0.05);
            padding: 3rem;
            border-radius: 16px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(245, 241, 232, 0.1);
            margin-top: 2rem;
        }

        .contact-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .contact-phone {
            font-size: 1.5rem;
            color: var(--sunset);
            text-decoration: none;
            display: inline-block;
            margin: 1rem 0;
            transition: transform 0.3s ease;
        }

        .contact-phone:hover {
            transform: scale(1.05);
        }

        /* Experience Section */
        .experience {
            background: var(--sand);
            text-align: center;
        }

        .luxury-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
            margin-top: 3rem;
        }

        .luxury-item {
            padding: 2rem;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }

        .luxury-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        .luxury-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: block;
        }

        /* Checklist Section */
        .checklist {
            background: white;
        }

        .checklist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .checklist-category {
            background: var(--warm-white);
            padding: 2rem;
            border-radius: 12px;
            border-top: 4px solid var(--ocean-mid);
        }

        .checklist-category h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.3rem;
            color: var(--ocean-deep);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .checklist-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.8rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .checklist-item:last-child {
            border-bottom: none;
        }

        .checkbox {
            width: 24px;
            height: 24px;
            border: 2px solid var(--ocean-mid);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .checkbox:hover {
            background: var(--ocean-mid);
            color: white;
        }

        .checkbox.checked {
            background: var(--ocean-mid);
            color: white;
        }

        /* Footer */
        .footer {
            background: var(--ocean-deep);
            color: var(--sand);
            text-align: center;
            padding: 4rem 2rem;
            min-height: auto;
        }

        .footer h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .maori-text {
            font-size: 1.2rem;
            color: var(--sunset);
            margin-top: 2rem;
            font-style: italic;
        }

        /* Print Section - QR Code */
        .print-section {
            display: none;
            background: white;
            padding: 3rem 2rem;
            text-align: center;
            border-top: 4px solid var(--ocean-deep);
        }

        .qr-container {
            display: inline-block;
            padding: 2rem;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            margin: 2rem 0;
        }

        #qrcode {
            margin: 0 auto;
        }

        .qr-instructions {
            margin-top: 1.5rem;
            color: var(--ocean-mid);
            font-size: 0.9rem;
        }

        .print-url {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.1rem;
            color: var(--ocean-deep);
            margin-top: 1rem;
            word-break: break-all;
        }

        .print-button {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--ocean-deep);
            color: white;
            border: none;
            padding: 1rem 2rem;
            border-radius: 50px;
            cursor: pointer;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.9rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
            z-index: 1001;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .print-button:hover {
            background: var(--ocean-mid);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {
                transform: translateX(-50%) translateY(0);
            }
            40% {
                transform: translateX(-50%) translateY(-10px);
            }
            60% {
                transform: translateX(-50%) translateY(-5px);
            }
        }

        @keyframes wave {
            0%, 100% { transform: rotate(0deg); }
            25% { transform: rotate(-10deg); }
            75% { transform: rotate(10deg); }
        }

        /* Print Styles */
        @media print {
            @page {
                size: A4;
                margin: 0;
            }

            body {
                background: white;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .nav-dots, 
            .scroll-indicator,
            .print-button,
            .checkbox {
                display: none !important;
            }

            section {
                min-height: auto;
                page-break-inside: avoid;
                padding: 2rem;
                display: block;
            }

            .hero {
                height: auto;
                padding: 3rem 2rem;
                page-break-after: always;
            }

            .hero-content {
                animation: none;
            }

            .info-card,
            .guideline-item,
            .luxury-item,
            .checklist-category,
            .cat-container,
            .contact-card,
            .restaurant-card,
            .activity-card,
            .appliance-card,
            .streaming-card {
                box-shadow: none;
                border: 1px solid #ddd;
                break-inside: avoid;
            }

            .print-section {
                display: block;
                page-break-before: always;
                padding: 4rem 2rem;
            }

            .qr-container {
                box-shadow: none;
                border: 2px solid var(--ocean-deep);
            }

            /* Ensure background colors print */
            .hero,
            .welcome,
            .guidelines,
            .cat-section,
            .contact,
            .experience,
            .checklist,
            .footer,
            .dining-section,
            .activities-section,
            .appliance-section,
            .streaming-section {
